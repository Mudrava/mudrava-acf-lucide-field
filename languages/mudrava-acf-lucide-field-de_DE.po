#. Plugin Name of the plugin
msgid "Mudrava Icon Field for ACF with Lucide"
msgstr "Mudrava Icon-Feld für ACF mit Lucide"

#. Description of the plugin
msgid "A custom ACF field type for selecting Lucide icons with a visual picker interface."
msgstr "Ein benutzerdefinierter ACF-Feldtyp zur Auswahl von Lucide-Symbolen mit einer visuellen Auswahlschnittstelle."

#. Author of the plugin
msgid "Mudrava"
msgstr "Mudrava"

#. Author URI of the plugin
msgid "https://mudrava.com"
msgstr "https://mudrava.com"

#: mudrava-acf-lucide-field.php:116
msgid "Docs"
msgstr "Dokumentation"

#: includes/class-mudrava-acf-field-lucide-icon.php:47
msgid "Lucide Icon"
msgstr "Lucide-Symbol"

#: includes/class-mudrava-acf-field-lucide-icon.php:91
#: includes/class-mudrava-acf-field-lucide-icon.php:153
msgid "Search icons..."
msgstr "Symbole suchen..."

#: includes/class-mudrava-acf-field-lucide-icon.php:92
#: includes/class-mudrava-acf-field-lucide-icon.php:183
msgid "No icons found"
msgstr "Keine Symbole gefunden"

#: includes/class-mudrava-acf-field-lucide-icon.php:93
#: includes/class-mudrava-acf-field-lucide-icon.php:169
msgid "Clear selection"
msgstr "Auswahl aufheben"

#: includes/class-mudrava-acf-field-lucide-icon.php:164
msgid "No icon selected"
msgstr "Kein Symbol ausgewählt"

#: includes/class-mudrava-acf-field-lucide-icon.php:207
msgid "Default Value"
msgstr "Standardwert"

#: includes/class-mudrava-acf-field-lucide-icon.php:208
msgid "Enter the icon name to be selected by default (e.g., \"rocket\")."
msgstr "Geben Sie den Symbolnamen ein, der standardmäßig ausgewählt werden soll (z.\u00a0B. \"rocket\")."

#: includes/class-mudrava-acf-field-lucide-icon.php:217
msgid "Return Format"
msgstr "Rückgabeformat"

#: includes/class-mudrava-acf-field-lucide-icon.php:218
msgid "Specify the format returned by get_field()."
msgstr "Geben Sie das von get_field() zurückgegebene Format an."

#: includes/class-mudrava-acf-field-lucide-icon.php:222
msgid "Icon Name (e.g., \"rocket\")"
msgstr "Symbolname (z.\u00a0B. \"rocket\")"

#: includes/class-mudrava-acf-field-lucide-icon.php:223
msgid "SVG Markup"
msgstr "SVG-Markup"

#: includes/class-mudrava-acf-field-lucide-icon.php:232
msgid "Placeholder"
msgstr "Platzhalter"

#: includes/class-mudrava-acf-field-lucide-icon.php:233
msgid "Placeholder text for the search input."
msgstr "Platzhaltertext für das Suchfeld."

#: includes/class-mudrava-acf-field-lucide-icon.php:253
msgid "Allow Null"
msgstr "Null erlauben"

#: includes/class-mudrava-acf-field-lucide-icon.php:254
msgid "Allow the field to have no icon selected."
msgstr "Erlauben, dass kein Symbol ausgewählt ist."

#: includes/class-mudrava-acf-field-lucide-icon.php:323
msgid "Please select an icon."
msgstr "Bitte wählen Sie ein Symbol aus."
